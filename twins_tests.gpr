with "twins_config.gpr";
with "twins_tests_deps.gpr";
with "twins.gpr";

project Twins_Tests is
   for Source_Dirs use ("tests");
   for Object_Dir use "target/" & Twins_Config.Build_Profile & "/obj-tests";
   for Exec_Dir use "target/" & Twins_Config.Build_Profile & "/bin";
   for Main use ("tests_main.adb");

   package Binder is
      for Default_Switches ("Ada") use Twins_Config.Binder_Switches;
   end Binder;

   package Builder is
      for Executable ("tests_main.adb") use "tests";
      for Default_Switches ("Ada") use Twins_Config.Builder_Switches;
   end Builder;

   package Compiler is
      for Default_Switches ("Ada") use Twins_Config.Compiler_Switches;
   end Compiler;

   package Linker is
      for Default_Switches ("Ada") use Twins_Config.Linker_Switches;
   end Linker;
end Twins_Tests;
